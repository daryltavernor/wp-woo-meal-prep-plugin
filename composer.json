{
  "name": "fastnutrition/mealprep",
  "description": "Fast Nutrition Meal Prep — WooCommerce plugin for the meal-prep ordering, management, and delivery system.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1",
    "dompdf/dompdf": "^3.0",
    "yahnis-elsts/plugin-update-checker": "^5.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "autoload": {
    "psr-4": {
      "FastNutrition\\MealPrep\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs"
  }
}
