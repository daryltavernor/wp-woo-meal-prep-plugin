# Keep the GitHub source archive (the zip the plugin updater downloads) lean:
# exclude development-only files the running plugin never loads. There is no
# build step on the target site, so vendor/ and assets/build/ MUST stay — they
# are required at runtime and are deliberately NOT export-ignored here.

/.gitattributes              export-ignore
/.gitignore                  export-ignore
/.github                     export-ignore
/assets/src                  export-ignore
/tests                       export-ignore
/package.json                export-ignore
/package-lock.json           export-ignore
/webpack.config.js           export-ignore
/phpunit.xml.dist            export-ignore
/composer.lock               export-ignore
/CHECKOUT_PRICING.md         export-ignore
/IN_STORE_QUICK_ORDER_PLAN.md export-ignore
/REDIS_CACHE.md              export-ignore
