{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "fastnutrition/macro-calculator",
  "title": "Macro Calculator",
  "category": "widgets",
  "icon": "chart-pie",
  "description": "Interactive macro calculator pulling ingredients from the site and supporting custom entries.",
  "attributes": {
    "allowCustom": { "type": "boolean", "default": true },
    "showTargets": { "type": "boolean", "default": true }
  },
  "supports": { "html": false },
  "textdomain": "fastnutrition-mealprep",
  "editorScript": "file:./edit.js",
  "viewScript": "fn-macro-calculator",
  "style": "fn-front",
  "render": "file:./render.php"
}
